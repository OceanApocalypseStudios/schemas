{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "system": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "nullable": true,
                    "description": "The name of the system. Can be null."
                },
                "version": {
                    "type": "integer",
                    "nullable": false,
                    "description": "The version of the system. Use -1 to indicate no version."
                }
            },
            "required": []
        },
        "linuxDistro": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "nullable": true,
                    "description": "The name of the Linux distribution. Can be null."
                },
                "family": {
                    "type": "string",
                    "nullable": true,
                    "description": "The family of the Linux distribution. Can be null."
                }
            },
            "required": []
        },
        "processor": {
            "type": "object",
            "properties": {
                "architecture": {
                    "type": "string",
                    "nullable": true,
                    "description": "The architecture of the processor. Can be null."
                }
            },
            "required": []
        }
    },
    "required": []
}
